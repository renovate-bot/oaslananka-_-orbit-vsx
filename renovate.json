{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 6am on monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "automerge": false,
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps):",
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "matchPackageNames": ["vscode", "node"],
      "enabled": false,
      "description": "Do not auto-raise the supported VS Code or Node floor."
    },
    {
      "matchPackageNames": ["@types/vscode"],
      "enabled": false,
      "description": "VS Code API type floor follows the supported engines.vscode baseline."
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "area:ci", "theme:supply-chain"],
      "description": "Review major GitHub Action updates manually."
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ],
  "dependencyDashboard": true
}

{
  "name": "orbit-vsx",
  "displayName": "Orbit MCP & A2A",
  "description": "Monitor MCP servers, record debug sessions, and explore A2A agents from VS Code.",
  "version": "0.5.7",
  "publisher": "oaslananka",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.100.0",
    "node": ">=22.0.0"
  },
  "categories": [
    "Debuggers",
    "Other",
    "Visualization"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "a2a",
    "agent",
    "agent-card",
    "debug",
    "debug-recorder",
    "health-monitor",
    "developer-tools",
    "automation"
  ],
  "icon": "media/icon.png",
  "main": "./dist/extension.js",
  "extensionKind": [
    "workspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oaslananka/orbit-vsx.git"
  },
  "bugs": {
    "url": "https://github.com/oaslananka/orbit-vsx/issues"
  },
  "homepage": "https://github.com/oaslananka/orbit-vsx#readme",
  "galleryBanner": {
    "color": "#102033",
    "theme": "dark"
  },
  "packageManager": "pnpm@11.9.0",
  "activationEvents": [
    "onView:orbit.health",
    "onView:orbit.debug",
    "onView:orbit.a2a",
    "onView:orbit.mcp.explorer",
    "onCommand:orbit.health.refresh",
    "onCommand:orbit.debug.newSession",
    "onCommand:orbit.a2a.validate",
    "onCommand:orbit.mcp.explorer.refresh",
    "onFileSystem:file",
    "onCommand:orbit.health.setToken",
    "onCommand:orbit.health.clearToken",
    "onCommand:orbit.debug.setToken",
    "onCommand:orbit.debug.clearToken"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orbit",
          "title": "Orbit",
          "icon": "media/orbit.svg"
        }
      ]
    },
    "views": {
      "orbit": [
        {
          "id": "orbit.health",
          "name": "Health Monitor",
          "icon": "$(pulse)",
          "contextualTitle": "MCP Health"
        },
        {
          "id": "orbit.debug",
          "name": "Debug Recorder",
          "icon": "$(bug)",
          "contextualTitle": "Debug Sessions"
        },
        {
          "id": "orbit.a2a",
          "name": "A2A Explorer",
          "icon": "$(graph)",
          "contextualTitle": "A2A Agents"
        },
        {
          "id": "orbit.mcp.explorer",
          "name": "MCP Explorer",
          "icon": "$(plug)",
          "contextualTitle": "MCP Connections"
        }
      ]
    },
    "commands": [
      {
        "command": "orbit.health.refresh",
        "title": "Refresh",
        "category": "Orbit: Health",
        "icon": "$(refresh)"
      },
      {
        "command": "orbit.health.addServer",
        "title": "Add Server",
        "category": "Orbit: Health",
        "icon": "$(add)"
      },
      {
        "command": "orbit.health.removeServer",
        "title": "Remove Server",
        "category": "Orbit: Health",
        "icon": "$(trash)"
      },
      {
        "command": "orbit.health.openDetail",
        "title": "Open Detail",
        "category": "Orbit: Health"
      },
      {
        "command": "orbit.health.checkAll",
        "title": "Check All Servers",
        "category": "Orbit: Health"
      },
      {
        "command": "orbit.debug.newSession",
        "title": "New Session",
        "category": "Orbit: Debug",
        "icon": "$(add)"
      },
      {
        "command": "orbit.debug.refresh",
        "title": "Refresh",
        "category": "Orbit: Debug",
        "icon": "$(refresh)"
      },
      {
        "command": "orbit.debug.openSession",
        "title": "Open Session",
        "category": "Orbit: Debug"
      },
      {
        "command": "orbit.debug.closeSession",
        "title": "Close Session",
        "category": "Orbit: Debug"
      },
      {
        "command": "orbit.debug.search",
        "title": "Search Sessions",
        "category": "Orbit: Debug",
        "icon": "$(search)"
      },
      {
        "command": "orbit.debug.recordCommand",
        "title": "Record Terminal Command",
        "category": "Orbit: Debug"
      },
      {
        "command": "orbit.a2a.refresh",
        "title": "Refresh",
        "category": "Orbit: A2A",
        "icon": "$(refresh)"
      },
      {
        "command": "orbit.a2a.validate",
        "title": "Validate Agent Card",
        "category": "Orbit: A2A",
        "icon": "$(check)"
      },
      {
        "command": "orbit.a2a.discover",
        "title": "Discover Agents",
        "category": "Orbit: A2A",
        "icon": "$(search)"
      },
      {
        "command": "orbit.a2a.scaffold",
        "title": "Scaffold Agent",
        "category": "Orbit: A2A",
        "icon": "$(new-folder)"
      },
      {
        "command": "orbit.a2a.openCard",
        "title": "Open Agent Card",
        "category": "Orbit: A2A"
      },
      {
        "command": "orbit.mcp.explorer.refresh",
        "title": "Refresh",
        "category": "Orbit: MCP",
        "icon": "$(refresh)"
      },
      {
        "command": "orbit.health.setToken",
        "title": "Set Health Token",
        "category": "Orbit: Health",
        "icon": "$(key)"
      },
      {
        "command": "orbit.health.clearToken",
        "title": "Clear Health Token",
        "category": "Orbit: Health",
        "icon": "$(trash)"
      },
      {
        "command": "orbit.debug.setToken",
        "title": "Set Debug Token",
        "category": "Orbit: Debug",
        "icon": "$(key)"
      },
      {
        "command": "orbit.debug.clearToken",
        "title": "Clear Debug Token",
        "category": "Orbit: Debug",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "orbit.health.refresh",
          "when": "view == orbit.health",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Refresh health monitor server list"
          }
        },
        {
          "command": "orbit.health.addServer",
          "when": "view == orbit.health",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Register a new MCP server"
          }
        },
        {
          "command": "orbit.debug.newSession",
          "when": "view == orbit.debug",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Create a new debug session"
          }
        },
        {
          "command": "orbit.debug.search",
          "when": "view == orbit.debug",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Search debug sessions"
          }
        },
        {
          "command": "orbit.debug.refresh",
          "when": "view == orbit.debug",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Refresh debug session list"
          }
        },
        {
          "command": "orbit.a2a.refresh",
          "when": "view == orbit.a2a",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Refresh agent registry"
          }
        },
        {
          "command": "orbit.a2a.validate",
          "when": "view == orbit.a2a",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Validate an agent card file"
          }
        },
        {
          "command": "orbit.a2a.discover",
          "when": "view == orbit.a2a",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Discover agents from the registry"
          }
        },
        {
          "command": "orbit.mcp.explorer.refresh",
          "when": "view == orbit.mcp.explorer",
          "group": "navigation",
          "accessibilityInformation": {
            "label": "Refresh MCP connection list"
          }
        }
      ],
      "view/item/context": [
        {
          "command": "orbit.health.removeServer",
          "when": "view == orbit.health && viewItem == mcpServer",
          "group": "inline"
        },
        {
          "command": "orbit.health.openDetail",
          "when": "view == orbit.health && viewItem == mcpServer"
        },
        {
          "command": "orbit.debug.closeSession",
          "when": "view == orbit.debug && viewItem == debugSession"
        },
        {
          "command": "orbit.a2a.openCard",
          "when": "view == orbit.a2a && viewItem == a2aAgent"
        }
      ],
      "editor/context": [
        {
          "command": "orbit.a2a.validate",
          "when": "resourceFilename =~ /agent-card\\.json$/",
          "group": "orbit"
        }
      ],
      "commandPalette": [
        {
          "command": "orbit.health.openDetail",
          "when": "false"
        },
        {
          "command": "orbit.health.removeServer",
          "when": "false"
        },
        {
          "command": "orbit.debug.openSession",
          "when": "false"
        },
        {
          "command": "orbit.debug.closeSession",
          "when": "false"
        },
        {
          "command": "orbit.a2a.openCard",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Orbit",
      "properties": {
        "orbit.health.endpoint": {
          "type": "string",
          "default": "http://127.0.0.1:3000",
          "description": "HTTP endpoint for health-monitor-mcp server."
        },
        "orbit.health.token": {
          "type": "string",
          "default": "",
          "markdownDescription": "Deprecated legacy setting. Use the `Orbit: Health: Set Health Token` command so the bearer token is stored in VS Code SecretStorage.",
          "secret": true,
          "deprecationMessage": "Use the Orbit: Health: Set Health Token command. Orbit migrates this value to SecretStorage during activation."
        },
        "orbit.health.pollingIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often to poll health status automatically."
        },
        "orbit.health.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Health Monitor panel."
        },
        "orbit.health.alertOnDown": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when an MCP server goes down."
        },
        "orbit.health.alertOnRecover": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification when an MCP server recovers."
        },
        "orbit.debug.endpoint": {
          "type": "string",
          "default": "http://127.0.0.1:3001",
          "description": "HTTP endpoint for debug-recorder-mcp server."
        },
        "orbit.debug.token": {
          "type": "string",
          "default": "",
          "markdownDescription": "Deprecated legacy setting. Use the `Orbit: Debug: Set Debug Token` command so the bearer token is stored in VS Code SecretStorage.",
          "secret": true,
          "deprecationMessage": "Use the Orbit: Debug: Set Debug Token command. Orbit migrates this value to SecretStorage during activation."
        },
        "orbit.debug.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Debug Recorder panel."
        },
        "orbit.debug.maxSessionsShown": {
          "type": "number",
          "default": 50,
          "minimum": 10,
          "maximum": 500,
          "description": "Maximum number of debug sessions shown in the tree."
        },
        "orbit.debug.autoTrackVscodeSessions": {
          "type": "boolean",
          "default": false,
          "description": "Automatically create and close matching Debug Recorder sessions when VS Code debug sessions start and stop."
        },
        "orbit.debug.showEditorDecorations": {
          "type": "boolean",
          "default": false,
          "description": "Show debug session frequency hints inline in the editor."
        },
        "orbit.a2a.registryUrl": {
          "type": "string",
          "default": "http://127.0.0.1:3099",
          "description": "a2a-warp registry server URL."
        },
        "orbit.a2a.cliPath": {
          "type": "string",
          "default": "a2a-warp",
          "description": "Path to the a2a-warp CLI executable."
        },
        "orbit.a2a.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the A2A Explorer panel."
        },
        "orbit.a2a.autoValidateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Auto-validate agent-card.json files on save."
        },
        "orbit.a2a.localCardScanLimit": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 250,
          "description": "Maximum number of local agent-card.json files scanned per workspace folder."
        },
        "orbit.a2a.localCardExcludeGlob": {
          "type": "string",
          "default": "**/{node_modules,.git,dist,out,coverage}/**",
          "description": "Glob used to exclude folders from local A2A agent-card scanning."
        },
        "orbit.mcp.explorer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the MCP Explorer panel."
        }
      }
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "orbit.mcp.provider",
        "label": "Orbit MCP Servers"
      }
    ],
    "languageModelTools": [
      {
        "name": "orbit_get_mcp_health",
        "tags": [
          "orbit",
          "mcp",
          "health"
        ],
        "toolReferenceName": "orbitMcpHealth",
        "displayName": "Orbit MCP Health",
        "modelDescription": "Returns Orbit MCP health dashboard summary and redacted server status. Read-only and bounded.",
        "userDescription": "Read Orbit MCP health summary.",
        "canBeReferencedInPrompt": true,
        "icon": "$(pulse)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "refresh": {
              "type": "boolean",
              "default": true,
              "description": "Refresh before returning."
            }
          }
        }
      },
      {
        "name": "orbit_list_mcp_servers",
        "tags": [
          "orbit",
          "mcp",
          "servers"
        ],
        "toolReferenceName": "orbitMcpServers",
        "displayName": "Orbit MCP Servers",
        "modelDescription": "Lists configured MCP servers with status, uptime, latency, and redacted URLs. Read-only and bounded.",
        "userDescription": "List Orbit MCP servers.",
        "canBeReferencedInPrompt": true,
        "icon": "$(server)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "number",
              "minimum": 1,
              "maximum": 25,
              "default": 10,
              "description": "Maximum records to return; capped at 25."
            },
            "includePipelines": {
              "type": "boolean",
              "default": false,
              "description": "Include pipeline summaries."
            }
          }
        }
      },
      {
        "name": "orbit_search_debug_sessions",
        "tags": [
          "orbit",
          "debug",
          "search"
        ],
        "toolReferenceName": "orbitDebugSearch",
        "displayName": "Orbit Debug Search",
        "modelDescription": "Searches Orbit Debug Recorder sessions and returns bounded summaries. Read-only.",
        "userDescription": "Search Orbit debug sessions.",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-alt)",
        "inputSchema": {
          "type": "object",
          "required": [
            "query"
          ],
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Search query."
            },
            "limit": {
              "type": "number",
              "minimum": 1,
              "maximum": 25,
              "default": 10,
              "description": "Maximum records to return; capped at 25."
            }
          }
        }
      },
      {
        "name": "orbit_get_debug_session_context",
        "tags": [
          "orbit",
          "debug",
          "context"
        ],
        "toolReferenceName": "orbitDebugContext",
        "displayName": "Orbit Debug Context",
        "modelDescription": "Returns bounded context for one Orbit Debug Recorder session. Read-only.",
        "userDescription": "Read one debug session context.",
        "canBeReferencedInPrompt": true,
        "icon": "$(debug-console)",
        "inputSchema": {
          "type": "object",
          "required": [
            "sessionId"
          ],
          "properties": {
            "sessionId": {
              "type": "string",
              "minLength": 1,
              "description": "Debug session id."
            }
          }
        }
      },
      {
        "name": "orbit_list_a2a_agents",
        "tags": [
          "orbit",
          "a2a",
          "agents"
        ],
        "toolReferenceName": "orbitA2AAgents",
        "displayName": "Orbit A2A Agents",
        "modelDescription": "Lists A2A agents from the configured registry with validated bounded summaries. Read-only.",
        "userDescription": "List A2A agents.",
        "canBeReferencedInPrompt": true,
        "icon": "$(circuit-board)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "number",
              "minimum": 1,
              "maximum": 25,
              "default": 10,
              "description": "Maximum records to return; capped at 25."
            }
          }
        }
      },
      {
        "name": "orbit_validate_agent_card",
        "tags": [
          "orbit",
          "a2a",
          "validation"
        ],
        "toolReferenceName": "orbitA2ACardValidate",
        "displayName": "Orbit A2A Card Validate",
        "modelDescription": "Validates an A2A Agent Card from JSON text or a safe public HTTPS URL. Provide exactly one of cardJson or url. Read-only.",
        "userDescription": "Validate an A2A Agent Card.",
        "canBeReferencedInPrompt": true,
        "icon": "$(verified)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "cardJson": {
              "type": "string",
              "minLength": 2,
              "description": "Agent Card JSON text."
            },
            "url": {
              "type": "string",
              "minLength": 1,
              "description": "Agent Card URL."
            }
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build:prod",
    "build": "pnpm run clean:dist && node esbuild.js && node esbuild-webview.js",
    "build:prod": "pnpm run clean:dist && node esbuild.js --production && node esbuild-webview.js --production",
    "watch": "concurrently \"node esbuild.js --watch\" \"node esbuild-webview.js --watch\"",
    "typecheck": "pnpm run typecheck:extension && pnpm run typecheck:webview && pnpm run typecheck:test",
    "typecheck:extension": "tsc --noEmit",
    "typecheck:webview": "tsc -p webview-ui/tsconfig.json --noEmit",
    "typecheck:test": "tsc -p test/tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"webview-ui/src/**/*.{ts,tsx}\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"webview-ui/src/**/*.{ts,tsx}\" \"test/**/*.ts\" --fix",
    "format:check": "prettier --check \"**/*.{json,md,yml,ts,tsx,js,mjs}\"",
    "format": "prettier --write \"**/*.{json,md,yml,ts,tsx,js,mjs}\"",
    "test": "node ./test/runTests.js",
    "test:unit": "mocha --ui tdd \"test/unit/**/*.test.js\"",
    "test:compile": "node test/cleanGenerated.mjs && tsc -p test/tsconfig.json",
    "test:package": "pnpm run package && pnpm run smoke:package",
    "smoke:package": "pnpm run test:compile && node ./test/packageSmoke.js",
    "pretest:unit": "pnpm run build && pnpm run test:compile",
    "precoverage": "pnpm run pretest:unit",
    "coverage": "c8 --config .c8rc.json mocha --ui tdd \"test/unit/**/*.test.js\"",
    "package": "pnpm run build:prod && pnpm exec vsce package --no-dependencies",
    "deploy:marketplace": "pnpm exec vsce publish --no-dependencies",
    "deploy:ovsx": "pnpm exec ovsx publish --no-dependencies",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:unit && pnpm run coverage && pnpm run build && pnpm test && pnpm run test:package",
    "pretest": "pnpm run build && pnpm run test:compile",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "verify:headless": "xvfb-run -a pnpm run verify"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.2",
    "c8": "11.0.0",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "mocha": "^11.7.6",
    "ovsx": "^1.0.0",
    "prettier": "^3.8.4",
    "typescript": "^5.8.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Orbit keeps read-only views available in untrusted workspaces, but disables workspace file scans, local CLI validation/scaffolding, and mutating network operations until the workspace is trusted."
    }
  }
}
